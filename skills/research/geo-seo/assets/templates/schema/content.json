{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{BASE_URL}/#organization",
      "name": "{ORG_NAME}",
      "url": "{BASE_URL}",
      "logo": "{BASE_URL}/logo.png",
      "description": "{ORG_DESCRIPTION}",
      "sameAs": [
        "https://twitter.com/{HANDLE}",
        "https://github.com/{ORG}",
        "https://www.youtube.com/@{CHANNEL}"
      ]
    },
    {
      "@type": "Person",
      "@id": "{BASE_URL}/#author",
      "name": "{AUTHOR_NAME}",
      "url": "{AUTHOR_URL}",
      "jobTitle": "{JOB_TITLE}",
      "sameAs": [
        "https://twitter.com/{AUTHOR_HANDLE}",
        "https://www.linkedin.com/in/{AUTHOR_SLUG}"
      ],
      "knowsAbout": ["{TOPIC_1}", "{TOPIC_2}", "{TOPIC_3}"]
    },
    {
      "@type": "Article",
      "headline": "{HEADLINE}",
      "description": "{DESCRIPTION}",
      "image": "{OG_IMAGE_URL}",
      "datePublished": "{DATE_PUBLISHED}",
      "dateModified": "{DATE_MODIFIED}",
      "author": { "@id": "{BASE_URL}/#author" },
      "publisher": { "@id": "{BASE_URL}/#organization" },
      "mainEntityOfPage": "{ARTICLE_URL}",
      "wordCount": "{WORD_COUNT}",
      "articleSection": "{SECTION}",
      "keywords": ["{KW_1}", "{KW_2}", "{KW_3}"],
      "inLanguage": "en"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "{BASE_URL}" },
        { "@type": "ListItem", "position": 2, "name": "{SECTION}", "item": "{BASE_URL}/{SECTION_SLUG}" },
        { "@type": "ListItem", "position": 3, "name": "{HEADLINE}" }
      ]
    }
  ]
}
