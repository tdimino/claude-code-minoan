{
  "_comment": "Autoresearch configuration — generated by /autoresearch init, edit freely.",
  "version": 1,
  "repo_name": "${REPO_NAME}",
  "repo_description": "${REPO_DESCRIPTION}",
  "language": "${LANGUAGE}",
  "build_cmd": "${BUILD_CMD}",
  "test_cmd": "${TEST_CMD}",
  "lint_cmd": "${LINT_CMD}",
  "eval_script": ".lab/eval.py",
  "program_md": ".lab/program.md",
  "branch_prefix": "autoresearch",
  "keep_threshold": 0.005,
  "max_iterations": 50,
  "experiment_timeout_s": 300,
  "gate_weights": {
    "t1_build_test": 0.20,
    "t2_behavioral": 0.40,
    "t3_pipeline": 0.25,
    "t4_documentation": 0.15
  },
  "secondary_metrics": [],
  "scope": {
    "include": ${SCOPE_INCLUDE},
    "exclude": [".lab/", "vendor/", "node_modules/", ".git/", "target/", "__pycache__/", "dist/"]
  }
}
