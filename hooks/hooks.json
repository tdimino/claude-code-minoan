            {"type": "command", "command": "python3 ~/.claude/hooks/subagent-spawn-log.py", "async": true}
          ]
        }
      ],
      "SubagentStop": [
        {
          "matcher": "",
          "hooks": [
            {"type": "command", "command": "python3 ~/.claude/hooks/subagent-stop-log.py", "async": true}
          ]
        }
      ]
    },
    "statusLine": {
      "type": "command",
      "command": "~/.claude/hooks/statusline-monitor.sh",
      "padding": 0
    }
  }
}
