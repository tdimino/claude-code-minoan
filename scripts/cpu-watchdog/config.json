    "mdworker",
    "mds_stores",
    "mds",
    "photolibraryd",
    "photoanalysisd",
    "backupd",
    "Spotlight",
    "corespotlightd",
    "cloudd",
    "bird",
    "XprotectService",
    "installd",
    "softwareupdated",
    "logd",
    "fseventsd",
    "coreaudiod",
    "cargo",
    "rustc",
    "clang",
    "clang++",
    "cc",
    "c++",
    "ld",
    "lld",
    "ffmpeg",
    "ffprobe",
    "HandBrakeCLI",
    "ollama",
    "llama-cli"
  ],

  "enable_ram_watchdog": true,
  "rss_window_samples": 20,
  "rss_warn_mb": 800,
  "rss_alert_mb": 1200,
  "rss_critical_mb": 2000,
  "rss_claude_floor_mb": 100,
  "rss_growth_mb_per_min": 60,
  "rss_growth_min_samples": 5,
  "rss_cooldown_min": 60,

  "enable_orphan_mcp_watchdog": true,
